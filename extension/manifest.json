{
  "manifest_version": 3,
  "name": "JACOBI — Price Probe",
  "version": "0.2.0",
  "description": "Right-click any page to probe for price discrimination. JACOBI deploys 24 agents across location, device, cookie, and network tiers.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "JACOBI — Probe this price"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
