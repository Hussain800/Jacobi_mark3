{
  "manifest_version": 3,
  "name": "Jacobi Price Shield",
  "version": "0.1.0",
  "description": "Adversarial price-discrimination detection for travel and booking sites.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.booking.com/*",
    "*://*.expedia.com/*",
    "*://*.google.com/travel/*",
    "*://*.kayak.com/*",
    "*://*.united.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.booking.com/*",
        "*://*.expedia.com/*",
        "*://*.google.com/travel/*",
        "*://*.kayak.com/*",
        "*://*.united.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
