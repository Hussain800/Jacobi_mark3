# JACOBI - Frontend Environment Configuration
# Copy this to frontend/.env.local. Never commit real keys.

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase Auth + DB.
# Use the publishable (sb_publishable_*) or legacy anon key — never the service_role key.
NEXT_PUBLIC_SUPABASE_URL=https://dlxfhoquysrncxkelyxa.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe — publishable key only on the frontend. Test mode keys (pk_test_*)
# are fine for the hackathon demo. Never put the secret key here.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
