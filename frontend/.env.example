# JACOBI — Frontend Environment Configuration
# Copy this to frontend/.env or configure via Vercel dashboard.
# Never commit real keys.

# Backend API URL (defaults to localhost:8000 in development)
NEXT_PUBLIC_API_URL=http://localhost:8000

# NextAuth.js
AUTH_SECRET=your_secret_here
AUTH_GOOGLE_ID=your_client_id_here
AUTH_GOOGLE_SECRET=your_client_secret_here
