# JACOBI - Backend Environment Configuration
# Copy this to backend/.env or create .env.local at the repo root.
# Never commit real keys.

# Bright Data Unlocker API
BRIGHTDATA_API_KEY=
BRIGHTDATA_UNLOCKER_ZONE=mcp_unlocker

# Set true only after enabling Custom Headers & Cookies on the Bright Data
# Unlocker zone. The app still sends headers either way, but Bright Data may
# disregard them until the zone feature is enabled.
BRIGHTDATA_CUSTOM_HEADERS_ENABLED=false

# AI analysis providers
OPENCODE_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
