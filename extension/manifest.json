{
  "manifest_version": 3,
  "name": "JACOBI — Price Probe",
  "version": "0.3.0",
  "description": "Right-click any page to probe for price discrimination. JACOBI deploys 24 agents across location, device, cookie, and network tiers.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "http://localhost:8000/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "JACOBI \u2014 Probe this price"
  },
  "commands": {
    "probe-current-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Probe current page \u2014 immediately opens JACOBI with current URL"
    },
    "quick-probe-link": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Quick probe link \u2014 probes selected/hovered URL or current page"
    }
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
